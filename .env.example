# ══════════════════════════════════════════════════
#   AgriTech AI — Environment Variables
#   Copy to .env and fill in real values
# ══════════════════════════════════════════════════

# ── App ───────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# ── MongoDB ───────────────────────────────────────
# Local:
MONGODB_URI=mongodb://localhost:27017/agritech
# Docker (use this when running docker-compose):
# MONGODB_URI=mongodb://admin:agritech_secret@mongo:27017/agritech?authSource=admin
MONGO_USER=admin
MONGO_PASS=agritech_secret

# ── Redis ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────
JWT_SECRET=change_me_to_a_strong_random_string_min_32_chars
JWT_EXPIRES_IN=7d

# ── ML Service ────────────────────────────────────
ML_SERVICE_URL=http://localhost:5001

# ── OpenAI (RAG + Chat) ───────────────────────────
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
# Model options: gpt-3.5-turbo (cheap), gpt-4o-mini (best value), gpt-4o (best quality)
OPENAI_MODEL=gpt-3.5-turbo

# ── GROQ API (Fast LLM) ───────────────────────────
# Get key at: https://groq.com
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# ── News API (Market Intelligence) ───────────────
# Get key at: https://newsapi.org
NEWS_API_KEY=your_news_api_key_here

# ── SERPER API (Web Search) ──────────────────────
# Get key at: https://serper.dev
SERPER_API_KEY=f62ac14f6a963f3b6976a9dbd78247aa1bc46cd8
SERPER_ENABLED=true

# ── Weather API ───────────────────────────────────
# Free tier at: https://www.weatherapi.com
# 1 million calls/month free — sufficient for most farms
WEATHER_API_KEY=2c10a93d62a446bd959100840260604

# ── SMS Notifications (MSG91 — India) ────────────
# Sign up at: https://msg91.com
MSG91_API_KEY=
MSG91_FLOW_ID=

# ── Push Notifications (Firebase) ────────────────
# From Firebase Console → Project Settings → Cloud Messaging
FCM_SERVER_KEY=

# ── WhatsApp (Twilio) — optional ─────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=+14155238886

# ── Python ML Service ─────────────────────────────
# (same OPENAI_API_KEY is used by both Node.js and Python)
ENV=development
